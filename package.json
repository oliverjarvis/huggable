{
  "name": "huggable",
  "version": "0.1.0",
  "description": "Deterministic design-system plugin: create, follow, and migrate-to design systems for React + React Native.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "default": "./dist/eslint/index.js"
    },
    "./variants": {
      "types": "./dist/variants/define-variants.d.ts",
      "default": "./dist/variants/define-variants.js"
    },
    "./registry": {
      "types": "./dist/registry/build-registry.d.ts",
      "default": "./dist/registry/build-registry.js"
    },
    "./tokens": {
      "types": "./dist/tokens/types.d.ts",
      "default": "./dist/tokens/types.js"
    },
    "./migrate": {
      "types": "./dist/migrate/plan.d.ts",
      "default": "./dist/migrate/plan.js"
    },
    "./cli/tokens-codegen": {
      "types": "./dist/cli/tokens-codegen.d.ts",
      "default": "./dist/cli/tokens-codegen.js"
    }
  },
  "files": ["dist"],
  "bin": {
    "huggable-tokens-codegen": "./dist/cli/tokens-codegen.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "codegen": "tsx src/cli/tokens-codegen.ts"
  },
  "dependencies": {
    "ts-morph": "^24.0.0"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "devDependencies": {
    "@types/estree-jsx": "^1.0.5",
    "@types/node": "^20",
    "eslint": "^9.13.0",
    "jiti": "^2.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
