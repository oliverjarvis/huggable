{
  "name": "huggable",
  "version": "0.1.0",
  "description": "Deterministic design-system plugin: create, follow, and migrate-to design systems for React + React Native.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "huggable-tokens-codegen": "src/cli/tokens-codegen.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "codegen": "tsx src/cli/tokens-codegen.ts"
  },
  "devDependencies": {
    "@types/estree-jsx": "^1.0.5",
    "@types/node": "^20",
    "eslint": "^9.13.0",
    "jiti": "^2.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
